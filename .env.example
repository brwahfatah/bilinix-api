# =============================================================================
# BEELIIN HOSTING — Laravel Backend
# =============================================================================
# Copy this file to .env and fill in every blank value before running.
# Lines starting with # are comments and are ignored by Laravel.
# =============================================================================

# =============================================================================
# APP
# =============================================================================

APP_NAME="Beeliin Hosting"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=UTC

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# =============================================================================
# DATABASE
# =============================================================================

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# =============================================================================
# CACHE
# =============================================================================
# 'database' requires the cache table (php artisan cache:table && migrate).
# Switch to 'redis' in production for better performance.

CACHE_STORE=database
CACHE_PREFIX=beeliin_

# =============================================================================
# QUEUE
# =============================================================================
# 'database' requires the jobs table (php artisan queue:table && migrate).
# Switch to 'redis' or 'sqs' in production.

QUEUE_CONNECTION=database

# =============================================================================
# SESSION
# =============================================================================

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

# =============================================================================
# SANCTUM
# =============================================================================
# Comma-separated list of domains allowed to use Sanctum cookie auth.
# For pure token-based (Bearer) auth this can be left blank.
# Example: localhost:3000,yourdomain.com

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1
SANCTUM_TOKEN_PREFIX=

# =============================================================================
# CORS
# =============================================================================
# Must match the Nuxt 4 frontend origin exactly (no trailing slash).
# config/cors.php reads FRONTEND_URL for allowed_origins.

FRONTEND_URL=http://localhost:3000

# =============================================================================
# MAIL
# =============================================================================

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# WHMCS INTEGRATION
# =============================================================================
# API credentials from WHMCS Admin → API Credentials.
# WHMCS_API_URL must be the base URL of your WHMCS install (no trailing slash).
# The backend appends /includes/api.php automatically.
#
# WHMCS_ACCESS_KEY is optional; leave blank if not configured in WHMCS.

WHMCS_API_URL=
WHMCS_IDENTIFIER=
WHMCS_SECRET=
WHMCS_ACCESS_KEY=

# Support department IDs — must match WHMCS Admin → Support → Departments
WHMCS_DEPT_TECHNICAL=1
WHMCS_DEPT_BILLING=2
WHMCS_DEPT_SALES=3
WHMCS_DEPT_GENERAL=4

# =============================================================================
# STRIPE
# =============================================================================
# Secret key: Stripe Dashboard → Developers → API keys.
# Use sk_test_xxx for development, sk_live_xxx for production.
#
# Webhook secret: Stripe Dashboard → Developers → Webhooks → Signing secret.
# Required for POST /api/payments/webhook/stripe signature verification.
#
# Success/cancel URLs are where Stripe redirects the user after checkout.
# These should point to your Nuxt 4 frontend pages.

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=USD
STRIPE_SUCCESS_URL=http://localhost:3000/dashboard/billing?payment=success
STRIPE_CANCEL_URL=http://localhost:3000/dashboard/billing?payment=cancelled

# =============================================================================
# FRONTEND
# =============================================================================
# FRONTEND_URL is also read by config/cors.php (allowed_origins).
# ADMIN_URL is used when constructing admin-side redirect links.

FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000/admin

# =============================================================================
# LOGGING
# =============================================================================

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# DEV FLAGS
# =============================================================================
# Set ENABLE_DEV_MOCKS=true to return stubbed WHMCS responses during
# local development without a live WHMCS instance.

ENABLE_DEV_MOCKS=false
