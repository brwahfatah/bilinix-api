# =============================================================================
# BEELIIN HOSTING — Laravel API
# Production Environment Template
# =============================================================================
# Copy this file to .env on the server and fill in every placeholder.
# Placeholders follow the pattern: DESCRIBE_WHAT_GOES_HERE
# Never commit a filled-in .env to version control.
# Generate APP_KEY with: php artisan key:generate --show
# =============================================================================

# =============================================================================
# APP
# =============================================================================

APP_NAME="Beeliin Hosting"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_PHP_ARTISAN_KEY_GENERATE
APP_DEBUG=false
APP_URL=https://api.yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=UTC

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database
BCRYPT_ROUNDS=12

# =============================================================================
# DATABASE
# =============================================================================

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password

# =============================================================================
# REDIS
# =============================================================================
# Used for cache, sessions, and queues in production.
# Bind Redis to 127.0.0.1 and set requirepass in /etc/redis/redis.conf.

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=your_redis_password
REDIS_PORT=6379

# =============================================================================
# CACHE
# =============================================================================
# Use 'redis' in production (faster than 'database').
# CACHE_PREFIX namespaces keys — keep 'beeliin_' to avoid collisions.

CACHE_STORE=redis
CACHE_PREFIX=beeliin_

# =============================================================================
# QUEUE
# =============================================================================
# Use 'redis' in production.
# Supervisor workers must be running: supervisorctl start beeliin-worker:*

QUEUE_CONNECTION=redis

# =============================================================================
# SESSION
# =============================================================================
# Use 'redis' in production.
# SESSION_DOMAIN must start with a dot to cover all subdomains.

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.yourdomain.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# =============================================================================
# SANCTUM
# =============================================================================
# Comma-separated list of domains that may send authenticated API requests.
# Must include both the API domain and the Nuxt 4 frontend domain.
# Bearer-token auth is used — no cookie/SPA auth required.

SANCTUM_STATEFUL_DOMAINS=yourdomain.com,api.yourdomain.com
SANCTUM_TOKEN_PREFIX=

# =============================================================================
# CORS
# =============================================================================
# Must match the Nuxt 4 frontend origin exactly — no trailing slash.
# config/cors.php reads FRONTEND_URL for allowed_origins.

FRONTEND_URL=https://yourdomain.com
ADMIN_URL=https://yourdomain.com/admin

# =============================================================================
# MAIL
# =============================================================================

MAIL_MAILER=smtp
MAIL_HOST=smtp.your-mail-provider.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="Beeliin Hosting"

# =============================================================================
# WHMCS INTEGRATION
# =============================================================================
# WHMCS Admin → Setup → API Credentials → Add API Role.
# WHMCS_API_URL: base URL of your WHMCS install — no trailing slash.
# WHMCS_ACCESS_KEY: optional; leave blank if not set in WHMCS configuration.
# Department IDs must match WHMCS Admin → Support → Departments.

WHMCS_API_URL=https://billing.yourdomain.com
WHMCS_IDENTIFIER=your_whmcs_api_identifier
WHMCS_SECRET=your_whmcs_api_secret
WHMCS_ACCESS_KEY=

WHMCS_DEPT_TECHNICAL=1
WHMCS_DEPT_BILLING=2
WHMCS_DEPT_SALES=3
WHMCS_DEPT_GENERAL=4

# =============================================================================
# STRIPE
# =============================================================================
# Stripe Dashboard → Developers → API keys.
# Use sk_live_* for production, sk_test_* for staging.
#
# Webhook secret: Stripe Dashboard → Developers → Webhooks → Signing secret.
# Required for POST /api/payments/webhook/stripe signature verification.
#
# Success/cancel URLs point to the Nuxt 4 frontend billing pages.

STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret
STRIPE_CURRENCY=USD
STRIPE_SUCCESS_URL=https://yourdomain.com/dashboard/billing?payment=success
STRIPE_CANCEL_URL=https://yourdomain.com/dashboard/billing?payment=cancelled

# =============================================================================
# LOGGING
# =============================================================================
# LOG_STACK=daily writes one file per day and auto-rotates after LOG_DAILY_DAYS.
# LOG_LEVEL=error suppresses debug/info noise in production.

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error
LOG_DAILY_DAYS=14

# =============================================================================
# PROVISIONING
# =============================================================================
# 'fake' returns stubbed responses without calling any real provider.
# Switch to the real provider driver when live provisioning is enabled.

PROVISION_DRIVER=fake

# =============================================================================
# DEV FLAGS
# =============================================================================
# Must be false in production. Setting true returns stubbed WHMCS responses
# and bypasses all real WHMCS API calls.

ENABLE_DEV_MOCKS=false
